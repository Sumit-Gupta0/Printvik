# Environment Configuration
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/printvik

# JWT Secret
JWT_SECRET=printvik_secret_key_2024_change_in_production

# Razorpay (Payment Gateway) - Add your keys when ready
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio (WhatsApp Integration) - Add your keys when ready
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Email Configuration - Add your email when ready
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Frontend URLs
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:3001
OPERATOR_URL=http://localhost:3002
DELIVERY_URL=http://localhost:3004

# Document Auto-Delete (days)
DOCUMENT_RETENTION_DAYS=7
